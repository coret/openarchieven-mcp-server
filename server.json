{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.coret/openarchieven-mcp-server",
  "title": "Open Archives",
  "description": "MCP server for the Open Archives genealogical search engine, including full-text page transcriptions of historical documents.",
  "websiteUrl": "https://www.openarchieven.nl",
  "repository": {
    "url": "https://github.com/coret/openarchieven-mcp-server",
    "source": "github"
  },
  "version": "1.0.0",
  "packages": [
    {
      "registryType": "npm",
      "identifier": "@coret/openarchieven-mcp-server",
      "version": "1.0.0",
      "transport": {
        "type": "stdio"
      }
    }
  ],
  "remotes": [
    {
      "type": "streamable-http",
      "url": "https://mcp.openarchieven.nl/"
    }
  ]
}