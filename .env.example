# Server port
PORT=3001

# Path to OpenAPI YAML (relative to mcp/ directory, or a URL)
OPENAPI_PATH=../api/openapi.yaml

# Upstream API base URL
UPSTREAM_BASE=https://api.openarchieven.nl/1.1

# Rate limit to upstream API (requests per second)
RATE_LIMIT_RPS=4

# Redis connection URL (optional — server runs without Redis)
REDIS_URL=redis://localhost:6379/5

# Redis cache TTL in seconds — fallback for tools not in the per-tool TTL map.
# Most tools use a tuned per-endpoint TTL (see TOOL_TTL in server.ts):
#   - Historical weather/census  : never expires (immutable)
#   - Archives metadata          : 7 days
#   - Stats aggregations         : 1 day
#   - Individual record lookups  : 1 day
#   - Search / match / births /  : 6 hours
#     deaths / marriages /
#     transcription search/browse
#   - get_births_years_ago       : until next UTC midnight
CACHE_TTL=3600

# Log level: trace | debug | info | warn | error | fatal
# In development (NODE_ENV != production) logs are pretty-printed; in production they are JSON.
LOG_LEVEL=info

# Extra Origin headers allowed on the MCP endpoint (comma-separated).
# Claude domains (claude.ai, claude.com, *.claude.ai, *.claude.com) are always allowed.
# Requests without an Origin header (curl, native MCP clients) are always allowed.
# Example: ALLOWED_ORIGINS=https://example.com,https://app.example.org
ALLOWED_ORIGINS=
